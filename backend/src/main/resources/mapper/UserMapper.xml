<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.snsapp.backend.mapper.UserMapper">

    <resultMap id="UserResultMap" type="com.snsapp.backend.entity.User">
        <id property="id" column="id"/>
        <result property="email" column="email"/>
        <result property="passwordHash" column="password_hash"/>
        <result property="displayName" column="display_name"/>
        <result property="bio" column="bio"/>
        <result property="avatarUrl" column="avatar_url"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="countUsers" resultType="long">
        SELECT COUNT(*) FROM users
    </select>

    <select id="findByEmail" resultMap="UserResultMap">
        SELECT id, email, password_hash, display_name, bio, avatar_url, created_at, updated_at
        FROM users
        WHERE email = #{email}
    </select>

    <select id="findById" resultMap="UserResultMap">
        SELECT id, email, password_hash, display_name, bio, avatar_url, created_at, updated_at
        FROM users
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.snsapp.backend.entity.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users (email, password_hash, display_name)
        VALUES (#{email}, #{passwordHash}, #{displayName})
    </insert>

</mapper>
