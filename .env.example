DB_NAME=sns_application
DB_USER=sns_user
DB_PASSWORD=change_me_locally
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_bytes

# 画像保存(現状はローカルディスク)。将来AWS S3へ移行する際はこの2つをS3/CloudFrontのURLに向ける想定
# (StorageServiceの実装差し替えのみで、呼び出し側コードの変更は不要)。
STORAGE_UPLOAD_DIR=uploads
STORAGE_BASE_URL=http://localhost:8080/uploads
